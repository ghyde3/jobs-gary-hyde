# Resend API key for the contact form. Get one at https://resend.com
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO=Gary.Robert.Hyde@gmail.com

# The "from" address for contact emails.
# Until a domain is verified in Resend, leave this unset (it defaults to
# onboarding@resend.dev, which can only deliver to the Resend account owner's
# own email). After verifying a domain at resend.com/domains, set this to an
# address on that domain, e.g. "Gary Hyde <noreply@garyhyde.com>", and then
# CONTACT_TO can be any address.
CONTACT_FROM=
